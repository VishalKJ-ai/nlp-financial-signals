#!/bin/zsh
# One-command interview demo.
#   ./demo         -> Act 1 only: FinBERT beats the dictionary (the win)
#   ./demo limits  -> Act 1 + Act 2: adds the tone-vs-stance boundary
#   ./demo tests   -> run the test suite
cd "$(dirname "$0")"
export HF_HUB_OFFLINE=1                  # model is cached locally; no network needed
export HF_HUB_DISABLE_PROGRESS_BARS=1    # no progress-bar smear in terminal
export TQDM_DISABLE=1
if [[ "$1" == "tests" ]]; then
  exec ./.venv/bin/python -m pytest tests/ -q -p no:warnings
fi
exec ./.venv/bin/python demo_score.py "$1"
