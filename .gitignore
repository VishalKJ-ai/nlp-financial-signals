# =============================================================================
# NLP Financial Signals Pipeline — .gitignore
# =============================================================================

# -- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# -- Distribution / packaging ------------------------------------------------
*.egg-info/
*.egg
dist/
build/
.eggs/

# -- Virtual environments ----------------------------------------------------
.venv/
venv/
env/

# -- IDE / Editor ------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -- Jupyter -----------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -- Testing -----------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/

# -- Data (raw downloads too large for version control) ----------------------
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# -- Trained models (large binary files) -------------------------------------
models/*
!models/.gitkeep

# -- Generated outputs (re-generated by pipeline) ---------------------------
outputs/figures/*
!outputs/figures/.gitkeep
outputs/signals/*
!outputs/signals/.gitkeep

# -- BERTopic / Transformer model cache --------------------------------------
topic_models/
sentence_transformers/

# -- Pipeline logs -----------------------------------------------------------
*.log
pipeline.log

# -- Environment variables ---------------------------------------------------
.env
.env.local
